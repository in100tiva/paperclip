# DDD — Paperclip da Equipe — Environment template
#
# 📋 Setup (one-time per developer):
# 1. Copy this file: `cp .env.example .env.local`
# 2. Fill in the values marked TODO_FILL_ME below
# 3. NEVER commit .env.local — it's gitignored. NEVER paste real values into THIS file.
# 4. Pre-commit hook (.husky/pre-commit) will block commits with leaked JWTs anyway.
#
# Phase 2 references: INFRA-04, AUTH-02, AUTH-05.

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
PORT=3100
SERVE_UI=true

# Cookie prefix derives from this — all team devs MUST share the same value
# so sessions stay coherent across machines (AUTH-02).
PAPERCLIP_INSTANCE_ID=team-shared

# ─────────────────────────────────────────────────────────────
# Database (Supabase Postgres — shared team backend)
#
# Project: bxlczioxgizgvtznukwt (sa-east-1)
# Pooler hostname: aws-1-sa-east-1.pooler.supabase.com (verified empirically; see MIGRATION_AUDIT.md)
# Username pattern: postgres.<project-ref>
#
# DATABASE_URL  → port 6543 (Supavisor transaction pooler) for app runtime.
#                 packages/db/src/client.ts auto-detects port and applies `prepare: false`.
# SUPABASE_DB_URL → port 5432 (session pooler) for Drizzle migrations / DDL.
#                   `pnpm db:migrate` and `pnpm db:generate` use this preferentially.
#
# Direct connection (`db.<ref>.supabase.co:5432`) does NOT work in this env (free tier IPv6-only).
# Use pooler for both runtime AND migrations.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres.bxlczioxgizgvtznukwt:TODO_FILL_ME@aws-1-sa-east-1.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres.bxlczioxgizgvtznukwt:TODO_FILL_ME@aws-1-sa-east-1.pooler.supabase.com:5432/postgres

# Optional: Supabase HTTP API endpoints (used only if/when UI talks directly to Supabase
# for Realtime/Storage; not required for v1 with Better Auth + Express API).
SUPABASE_URL=https://bxlczioxgizgvtznukwt.supabase.co
SUPABASE_ANON_KEY=TODO_FILL_ME

# ⚠️  SERVICE ROLE KEY — server-only. NEVER prefix with VITE_ (that exposes to client bundle).
# Pre-commit hook blocks commits adding this in ui/src/** or as VITE_*SERVICE_ROLE*.
SUPABASE_SERVICE_ROLE_KEY=TODO_FILL_ME

# ─────────────────────────────────────────────────────────────
# Authentication (Better Auth, preserved in v1; AUTH-01..04)
# ─────────────────────────────────────────────────────────────
# Generate fresh per environment: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
# Do NOT reuse the upstream placeholder secret value — it's not safe.
BETTER_AUTH_SECRET=TODO_FILL_ME

# Optional override; defaults to BETTER_AUTH_SECRET if unset.
# PAPERCLIP_AGENT_JWT_SECRET=

# ─────────────────────────────────────────────────────────────
# Database backend mode (INFRA-06)
# ─────────────────────────────────────────────────────────────
# Default: Supabase (DATABASE_URL must be set above).
# Opt-in fallback: set to `embedded-postgres` to spin up a local embedded Postgres for offline work.
# When embedded mode is active, DATABASE_URL is IGNORED and a local instance runs at port 54329.
# PAPERCLIP_DB_MODE=embedded-postgres

# ─────────────────────────────────────────────────────────────
# Migration policy (DB-02)
# ─────────────────────────────────────────────────────────────
# Default: startup REFUSES to apply pending migrations (5+ devs sharing one Supabase →
# auto-apply is unsafe). Run `pnpm db:migrate` explicitly when needed.
#
# CI ONLY: GitHub Actions sets this to `true` to apply migrations after PR merge to main.
# Local devs: leave UNSET.
# PAPERCLIP_MIGRATION_AUTO_APPLY=true

# ─────────────────────────────────────────────────────────────
# Multi-Account Claude Code Configuration (Phase 5 — MULTI-04)
# ─────────────────────────────────────────────────────────────
# Cooldown em segundos entre rotações da mesma conta para evitar thrashing.
# Aplicado APÓS swap real — não bloqueia primeira detecção, apenas evita ping-pong
# entre 2 contas próximas do limite. Configurável por tier Anthropic distinto.
# Default: 30 (equilíbrio entre responsividade e estabilidade conforme
# DECISION-DETECTION-STRATEGY.md do spike Phase 4).
CLAUDE_ACCOUNT_COOLDOWN_SECONDS=30

# ─────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
